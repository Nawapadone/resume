<!DOCTYPE html>
<html lang="{{lang}}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{shortDescription}}" />
  <meta name="author" content="{{resume.name}}" />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#4f46e5" />
  <title>{{resume.name}} | {{resume.title}}</title>

  <link rel="canonical" href="{{canonicalUrl}}" />
  <link rel="alternate" hreflang="en" href="{{enUrl}}" />
  <link rel="alternate" hreflang="th" href="{{thUrl}}" />
  <link rel="alternate" hreflang="x-default" href="{{enUrl}}" />

  <meta property="og:type" content="profile" />
  <meta property="og:title" content="{{resume.name}} | {{resume.title}}" />
  <meta property="og:description" content="{{shortDescription}}" />
  <meta property="og:url" content="{{canonicalUrl}}" />
  <meta property="og:locale" content="{{ogLocale}}" />
  <meta property="og:locale:alternate" content="{{ogLocaleAlt}}" />
  <meta property="og:site_name" content="{{resume.name}}" />
  <meta property="og:image" content="{{enUrl}}/og-image.jpg" />
  <meta property="og:image:secure_url" content="{{enUrl}}/og-image.jpg" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:width" content="630" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="{{resume.name}} — {{resume.title}}" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{resume.name}} | {{resume.title}}" />
  <meta name="twitter:description" content="{{shortDescription}}" />
  <meta name="twitter:image" content="{{enUrl}}/og-image.jpg" />
  <meta name="twitter:image:alt" content="{{resume.name}} — {{resume.title}}" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <script type="application/ld+json">{{{jsonLd}}}</script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/output.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

  {{!-- Prevent dark-mode flash: read localStorage before first paint --}}
  <script>
    (function () {
      try {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      } catch (_) {}
    })();
  </script>
</head>
<body class="min-h-screen font-sans antialiased">

  {{> header}}

  <main id="main-content">
    {{{body}}}
  </main>

  {{> footer}}

  <script>
    document.getElementById('theme-toggle').addEventListener('click', function () {
      var html = document.documentElement;
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  </script>
</body>
</html>
